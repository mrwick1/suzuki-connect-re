<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        REDLINE mark: a tachometer swept into the redline. Center (54,54), r=30.
        Dial opens at the bottom (90deg gap). Sweep runs 135deg (lower-left) over
        the top to 45deg (lower-right). The last quarter on the right is the magenta
        redline; the needle points into it. All geometry inside the 18..90 safe area.
    -->

    <!-- Dial arc (lush green): 135deg over the top to 315deg -->
    <path
        android:strokeColor="#8FE03A"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M32.79,75.21 A30,30 0 0 1 75.21,32.79" />

    <!-- Redline tail (magenta): 315deg down the right side to 45deg -->
    <path
        android:strokeColor="#FF2D78"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M75.21,32.79 A30,30 0 0 1 75.21,75.21" />

    <!-- Needle into the redline, with a short counterweight tail -->
    <path
        android:strokeColor="#F2F7F0"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M46.12,55.39 L76.65,50.01" />

    <!-- Hub -->
    <path
        android:fillColor="#8FE03A"
        android:pathData="M54,54m-6,0a6,6 0 1 0,12 0a6,6 0 1 0,-12 0z" />
    <path
        android:fillColor="#0A1424"
        android:pathData="M54,54m-2.6,0a2.6,2.6 0 1 0,5.2 0a2.6,2.6 0 1 0,-5.2 0z" />
</vector>
