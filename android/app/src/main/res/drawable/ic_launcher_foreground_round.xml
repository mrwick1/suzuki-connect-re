<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        Round-icon variant of the REDLINE tachometer. Same mark, tighter radius
        (r=26 vs 30) so the dial is not clipped by the circular mask.
    -->

    <!-- Dial arc (lush green): 135deg over the top to 315deg -->
    <path
        android:strokeColor="#8FE03A"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M35.62,72.38 A26,26 0 0 1 72.38,35.62" />

    <!-- Redline tail (magenta): 315deg down the right side to 45deg -->
    <path
        android:strokeColor="#FF2D78"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M72.38,35.62 A26,26 0 0 1 72.38,72.38" />

    <!-- Needle into the redline -->
    <path
        android:strokeColor="#F2F7F0"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M47.11,55.22 L73.70,50.53" />

    <!-- Hub -->
    <path
        android:fillColor="#8FE03A"
        android:pathData="M54,54m-5.5,0a5.5,5.5 0 1 0,11 0a5.5,5.5 0 1 0,-11 0z" />
    <path
        android:fillColor="#0A1424"
        android:pathData="M54,54m-2.4,0a2.4,2.4 0 1 0,4.8 0a2.4,2.4 0 1 0,-4.8 0z" />
</vector>
