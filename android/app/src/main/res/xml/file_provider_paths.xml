<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider paths for sharing ride exports (GPX) from the cache dir
     and crash logs (filesDir/crash-logs) for the "Share crash log" button. -->
<paths>
    <cache-path name="exports" path="." />
    <files-path name="crash-logs" path="crash-logs/" />
    <files-path name="diag-logs" path="diag/" />
    <files-path name="ride-shares" path="rides/" />
</paths>
