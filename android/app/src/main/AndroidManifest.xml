<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE: Android 12+ -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />

    <!-- BLE on Android <12 still needs these (no-op on 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />

    <!-- GPS for ride track recording (FusedLocationProviderClient).
         Was previously declared with maxSdkVersion=30 for legacy BLE only;
         now needed at runtime on all API levels for ride GPX export. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Foreground service (BLE link) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Optional: auto-start on boot if user enables it -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Notification listener gives us: nav (Google Maps), calls (system Phone), SMS (system Messages), other apps -->
    <!-- NB: per assumptions log A9, we explicitly do NOT request READ_SMS / RECEIVE_SMS -->

    <!-- Weather: outbound HTTP -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Optional: phone location for weather (single-shot, only when user requests location-aware weather) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Safety: SOS path sends an SMS to the configured emergency contact when a crash is detected.
         Per Phase 1 research (A9), Play Store doesn't allow SEND_SMS for non-default-SMS apps; this
         app is sideloaded so the user grants it manually. -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Reliability: when the user swipes the app away from Recents we re-launch
         the foreground service via AlarmManager.setExactAndAllowWhileIdle (see
         BikeBridgeService.onTaskRemoved). On Android 12+ this requires one of
         these permissions; USE_EXACT_ALARM is auto-granted for sideloaded /
         calendar-class apps, SCHEDULE_EXACT_ALARM is the user-revocable variant
         and acts as a fallback. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Lets the crash-SOS prompt promote to a full-screen activity from the
         background (heads-up otherwise), so the rider can cancel in time. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- BLE hardware required -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:name=".GixxerApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GixxerBridge"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.GixxerBridge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service holding the BLE link -->
        <service
            android:name=".ble.BikeBridgeService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Full-screen "Are you OK?" prompt shown on suspected crash. Launched from the
             service with FLAG_ACTIVITY_NEW_TASK; not exported. -->
        <activity
            android:name=".safety.SosScreen"
            android:exported="false"
            android:launchMode="singleTask"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.GixxerBridge" />

        <!-- Captures Google Maps nav notifications + calls + SMS + arbitrary allowlisted apps -->
        <service
            android:name=".notifications.NotificationCaptureService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Boot receiver — only fires if user enabled auto-start -->
        <receiver
            android:name=".ble.BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Fires the crash SOS at the countdown deadline, even if the app
             process was killed during the countdown. Not exported — only our own
             AlarmManager PendingIntent triggers it. -->
        <receiver
            android:name=".safety.SosAlarmReceiver"
            android:exported="false" />

        <!-- FileProvider for sharing exported GPX files via ACTION_SEND. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
